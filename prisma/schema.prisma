datasource db {
      provider = "postgresql"
      url      = env("DATABASE_URL")
}

generator client {
      provider = "prisma-client-js"
}

enum Role {
      ADMIN
      TEACHER
      STUDENT
}

model User {
      id           String    @id @default(cuid())
      email        String    @unique
      passwordHash String
      name         String
      role         Role      @default(STUDENT)
      createdAt    DateTime  @default(now())
      updatedAt    DateTime  @updatedAt
      sessions     Session[]
}

model Session {
      id        String   @id
      userId    String
      expiresAt DateTime
      createdAt DateTime @default(now())
      user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

      @@index([userId])
}
